<Window x:Class="i_freeze.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
        xmlns:local="clr-namespace:i_freeze" 
        xmlns:Menu="clr-namespace:i_freeze.Utilities" 
        xmlns:vm="clr-namespace:i_freeze.ViewModel" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        xmlns:h="clr-namespace:i_freeze.Commands"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="650" 
        Width="850"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent">
    <!--<Window.Effect>
        <DropShadowEffect BlurRadius="15" Direction="90" RenderingBias="Quality" ShadowDepth="10"/>
    </Window.Effect>-->

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <i:Interaction.Behaviors>
        <h:WindowDragAndDrop />
    </i:Interaction.Behaviors>


    <Border>
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" 
                              RenderingBias="Quality" 
                              ShadowDepth="0" 
                              Opacity="0.8"
                              Color="Black"
                              />
        </Border.Effect>

        <Grid Margin="20">

            <Border Background="White" CornerRadius="10"/>

            <!-- main grid -->
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <!-- navigation bar -->
                <!-- Close Window -->
                <Border CornerRadius="10 10 0 0" Background="#fdfdfd" 
                        BorderThickness="0.5" BorderBrush="#B8B8B8"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                            VerticalAlignment="Center" Margin="10,0,0,0">
                    <Image Source="/Images/IceLockHeader.jpg" Width="39" 
                           HorizontalAlignment="Left"
                           Margin="0,1,5,0"
                    />
                    <TextBlock Text="ICE LOCK" FontSize="19"
                               FontWeight="SemiBold" Foreground="#FF175AA8"
                               VerticalAlignment="Center"/>
                </StackPanel>
              

                <Border HorizontalAlignment="Right" 
                    Margin="0,0,0,0"
                    Height="40" Width="40"
                    Style="{StaticResource CloseWindow}"
                    CornerRadius="0 10 0 0"
                    >

                    <Button Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}" 
                        Width="28" Height="28" Background="{x:Null}" 
                        BorderBrush="{x:Null}" Foreground="#FF175AA8"
                        Command="{Binding CloseCommand}"
                            IsCancel="True"
                        >

                        <materialDesign:PackIcon Kind="Close" HorizontalAlignment="Center" Height="28" VerticalAlignment="Center" Width="28"/>
                    </Button>
                </Border>

                <!-- Minimize -->
                <Border HorizontalAlignment="Right" 
                    Margin="0,0,40,0"
                    Height="40" Width="40"
                    Style="{StaticResource MinimizeWindow}"
                    >

                    <Button Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}" 
                        Width="28" Height="28" Background="{x:Null}" 
                        BorderBrush="{x:Null}" Foreground="#FF175AA8"
                        Command="{Binding MinimizeCommand}"
                        >

                        <materialDesign:PackIcon Kind="WindowMinimize" VerticalAlignment="Center"/>
                    </Button>

                </Border>



                <!-- base grid -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Switcher column 0 -->
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="49*"/>
                            <ColumnDefinition Width="116*"/>
                        </Grid.ColumnDefinitions>

                        <ContentControl x:Name="Switchers"
                                        Content="{Binding Source={x:Static Menu:AppSettings.Instance},
                                        Path=SwitcherView}" Grid.ColumnSpan="2"/>

                    </Grid>




                    <!-- views column 1 -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="299*"/>
                            <RowDefinition Height="271*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="500*"/>
                            <ColumnDefinition Width="127*"/>
                            <ColumnDefinition Width="18*"/>
                        </Grid.ColumnDefinitions>

                        <!--<ContentControl x:Name="Pages"
                                Content="{Binding CurrentView}" />-->

                        <ContentControl x:Name="Pages"
                                        Content="{Binding Source={x:Static Menu:AppSettings.Instance},
                                        Path=CurrentView}" Grid.ColumnSpan="3" Grid.RowSpan="2"/>

                    </Grid>
                </Grid>

            </Grid>

        </Grid>

    </Border>

</Window>
