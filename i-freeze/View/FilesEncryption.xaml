<UserControl x:Class="i_freeze.View.FilesProtection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
             xmlns:local="clr-namespace:i_freeze.View" 
             xmlns:vm="clr-namespace:i_freeze.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="560" d:DesignWidth="650"
             Style="{StaticResource Page_Style}">

    <UserControl.DataContext>
        <vm:FilesProtectionViewModel/>
    </UserControl.DataContext>

    <Grid Background="Transparent">
        <TextBlock HorizontalAlignment="Center" 
            Foreground="#FF175AA8" Height="43" 
            Margin="0,25,0,0" TextWrapping="Wrap" 
            VerticalAlignment="Top" Width="219"  
            Text="Files Encryption" FontSize="24"/>
        <Rectangle HorizontalAlignment="Center" Height="1" 
                   Margin="0,80,0,0" Stroke="#FF175AA8" 
                   VerticalAlignment="Top" Width="627"/>

        <TextBlock HorizontalAlignment="Left" Foreground="#FF175AA8" 
                   Height="33" Margin="80,115,0,0" TextWrapping="Wrap" 
                   VerticalAlignment="Top" Width="134"  
                   Text="Lock Files/Folders" FontSize="15" FontFamily="arial" />

        <Button Content="Select Path" HorizontalAlignment="Left" 
                Height="38" Margin="359,110,0,0" VerticalAlignment="Top" 
                Width="151" Background="#FF175AA8"
                Command="{Binding LockFileCommand}"/>

        <ListView x:Name="FilesList" Margin="0,60,0,0" 
                  Height="256" VerticalAlignment="Center"
                  ItemsSource="{Binding BlockedFiles}"
                  SelectedItem="{Binding File}"
                  SelectionMode="Multiple"
                  SelectionChanged="GetSelectedList"
                  Width="490"
                  HorizontalAlignment="Center"
                  BorderBrush="#FF175AA8" Foreground="#FF175AA8" 
                  >
            
            <ListView.Resources>
                <Style TargetType="{x:Type GridViewColumnHeader}">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="Foreground" Value="#FF175AA8"/>
                </Style>
                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                </Style>
            </ListView.Resources>
            
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="File/Folder Path" DisplayMemberBinding="{Binding Path}"/>
                </GridView>
            </ListView.View>
            
        </ListView>

        <Button Foreground="White" Background="#FF175AA8"  
                Margin="0,469,0,59" x:Name="ButtonShowResults_Copy2"
                HorizontalAlignment="Center"
                Content="Unlock"
                Width="100"
                Command="{Binding UnlockFileCommand}"
                RenderTransformOrigin="0.5,0.5"/>


    </Grid>

</UserControl>
