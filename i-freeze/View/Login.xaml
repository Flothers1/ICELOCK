<UserControl x:Class="i_freeze.View.Login"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:i_freeze.View"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:i_freeze.ViewModel" 
             xmlns:components="clr-namespace:i_freeze.Components"
             mc:Ignorable="d" 
             d:DesignHeight="560" d:DesignWidth="650"
             Style="{StaticResource Page_Style}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <!-- NOTE: No UserControl.DataContext here. The viewmodel from the DataTemplate/ContentControl
         will be set as the DataContext automatically. -->
<!--g-->
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border Background="#0453c3" CornerRadius="0 0 10 0">
            <Grid>
                <Image Height="140" VerticalAlignment="Top" HorizontalAlignment="Center"
                       Margin="0,80,0,0" Source="/Images/ICELOCKLogooo.png" />

                <StackPanel Margin="0,236,0,93" HorizontalAlignment="Center" >
                    <StackPanel Orientation="Horizontal" Margin="0 80 10 10" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="User" Width="25" Height="25" Foreground="White"/>
                        <TextBox x:Name="txtUsername" Margin="10 0" 
                                 materialDesign:HintAssist.Hint="Email"
                                 Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="White" Width="250" BorderBrush="White" CaretBrush="#FF175AA8" SelectionBrush="#FF175AA8"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0 0 10 10" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Lock" Width="25" Height="25" Foreground="White"/>
                        <components:BindablePasswordBox x:Name="Password"
                                                       Margin="10 0"
                                                       materialDesign:HintAssist.Hint="*******"
                                                       Foreground="White" Width="250"
                                                       Password="{Binding Password}"/>
                    </StackPanel>

                    <StackPanel Margin="0 10 0 10" Orientation="Horizontal" Width="150" HorizontalAlignment="Center">
                        <Button Width="150" Height="40" Style="{StaticResource MaterialDesignRaisedButton}" 
                                materialDesign:ButtonAssist.CornerRadius="10" BorderThickness="2"
                                BorderBrush="#FF175AA8"
                                Background="#FFC7CFD8" Foreground="#FF175AA8"
                                x:Name="btnLogin" Content="Login"
                                IsDefault="True"
                                Command="{Binding LoginCommand}"/>
                    </StackPanel>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</UserControl>
