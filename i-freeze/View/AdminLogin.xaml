<UserControl x:Class="i_freeze.View.AdminLogin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:i_freeze.ViewModel"
             xmlns:local="clr-namespace:i_freeze.View" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:components="clr-namespace:i_freeze.Components"
             mc:Ignorable="d" 
             d:DesignHeight="560" d:DesignWidth="650"
             Style="{StaticResource Page_Style}">
    <UserControl.DataContext>
        <vm:AdminLoginViewModel/>
    </UserControl.DataContext>
    <Border Background="#FF175AA8" CornerRadius="0 0 10 0">

        <Grid>
            <Image Height="140" VerticalAlignment="Top" HorizontalAlignment="Center"
       Margin="0,80,0,0" Source="/Images/ICELOCKLogooo.png" />


            <!--<TextBox HorizontalAlignment="Left" Margin="222,0,0,0" TextWrapping="Wrap" Text="Username" VerticalAlignment="Center" Width="88" Height="36" FontSize="18" BorderBrush="White" RenderTransformOrigin="1.08,0.198"/>
     <TextBox HorizontalAlignment="Left" Margin="225,325,0,0" TextWrapping="Wrap" Text="Password" VerticalAlignment="Top" Width="88" Height="37" FontSize="18" BorderBrush="White"/>-->
            <StackPanel Margin="120,236,120,93">
                <TextBlock Text="Admin Login" Margin="20" 
                        Foreground="White" 
                        TextAlignment="Center" 
                        FontSize="25" FontFamily="arial"/>

                <StackPanel Orientation="Horizontal" Margin="10">
                    <materialDesign:PackIcon Kind="User" 
                                          Width="25" 
                                          Height="25" 
                                          Foreground="White"/>

                    <TextBox x:Name="txtUsername" 
                          Margin="10 0" 
                          materialDesign:HintAssist.Hint="Enter Username"
                          Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Foreground="White" Width="250" 
                          BorderBrush="White" CaretBrush="#FF175AA8" 
                          SelectionBrush="#FF175AA8"/>

                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="10">
                    <materialDesign:PackIcon Kind="Lock" 
                                          Width="25" Height="25" 
                                          Foreground="White"/>

                    <components:BindablePasswordBox x:Name="Password"
                                                 Margin="10 0"
                                                 materialDesign:HintAssist.Hint="*******"
                                                 Foreground="White" Width="250"
                                                 Password="{Binding Password}"/>

                </StackPanel>

                <StackPanel Margin="10,10" 
                         Orientation="Horizontal" 
                         Width="315">

                    <Button Width="150" Height="40" 
                         Style="{StaticResource MaterialDesignRaisedButton}" 
                         materialDesign:ButtonAssist.CornerRadius="10" 
                         BorderThickness="2" BorderBrush="#FF175AA8"
                         Background="#FFC7CFD8" Foreground="#FF175AA8"  
                         x:Name="btnLogin" Content="Login"
                         IsDefault="True"
                         Command="{Binding LoginCommand}"/>

                    <!--<Button Width="100" Height="40" 
                     Style="{StaticResource MaterialDesignRaisedButton}" 
                     materialDesign:ButtonAssist.CornerRadius="10" 
                     BorderThickness="2" BorderBrush="#FF175AA8"
                     Background="#FFC7CFD8" Foreground="#FF175AA8"  
                     x:Name="btnBack" Content="Back"/>-->

                    <Button Width="150" Height="40"
                         Margin="10 0 0 0"
                         Style="{StaticResource MaterialDesignRaisedButton}" 
                         materialDesign:ButtonAssist.CornerRadius="10" 
                         BorderThickness="2" BorderBrush="#FF175AA8"
                         Background="#FFC7CFD8" Foreground="#FF175AA8"  
                         x:Name="btnBack_Copy" Content="Change Password"
                         Command="{Binding ChangePasswordCommand}"/>


                </StackPanel>

            </StackPanel>

        </Grid>
    </Border>

</UserControl>
