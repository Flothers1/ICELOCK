<Window x:Class="i_freeze.View.ProgressBar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:i_freeze.View" 
        xmlns:vm="clr-namespace:i_freeze.ViewModel" 
        xmlns:h="clr-namespace:i_freeze.Commands" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Scan Running"  mc:Ignorable="d" 
        Background="Transparent"  ResizeMode="NoResize" 
        AllowsTransparency="True"
        Height = "205" Width = "600" 
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        >

    <Window.DataContext>
        <vm:ProgressBarViewModel/>
    </Window.DataContext>

    <i:Interaction.Behaviors>
        <h:WindowDragAndDrop />
    </i:Interaction.Behaviors>



    <Border>

        <Border.Effect>
            <DropShadowEffect BlurRadius="15" 
                      RenderingBias="Quality" 
                      ShadowDepth="0" 
                      Opacity="0.8"
                      Color="Black"
                      />
        </Border.Effect>



        <Grid Margin="20">

            <Border Background="Transparent" CornerRadius="20"/>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White"
                        CornerRadius="20 20 0 0"
                        >

                    <Grid>

                        <Image Source="/Images/ICELOCK-01.jpg" Width="50" 
                               HorizontalAlignment="Left"
                               Margin="7 0 0 0"
                               />

                        <Border HorizontalAlignment="Right" 
                                Margin="0,0,0,0"
                                Height="40" Width="40"
                                Style="{StaticResource MinimizeWindow}"
                                CornerRadius="0 20 0 0"
                                >

                            <Button Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}" 
                                    Width="25" Height="25" Background="{x:Null}" 
                                    BorderBrush="{x:Null}" Foreground="#FF175AA8"
                                    Command="{Binding MinimizeCommand}"
                                    >

                                <materialDesign:PackIcon Kind="Close" 
                                                         HorizontalAlignment="Center"/>
                            </Button>
                        </Border>
                    </Grid>

                </Border>


                <Border Grid.Row="1"
                        Background = "#FF175AA8"
                        CornerRadius="0 0 20 20">

                    <Grid Background = "White" Margin="30,15,30,15" >

                        <TextBlock Text = "Update Running" 
                                   Foreground='#FF175AA8' 
                                   FontSize="16"
                                   Height="25" Margin="199,-1,182,71"/>

                        <ProgressBar x:Name = "pg2" 
                                     Margin = "10,30,10,50" 
                                     Height = "15" IsIndeterminate = "True" 
                                     Background="#FF175AA8" 
                                     BorderBrush="#FF175AA8" 
                                     Foreground="#FF74A3D1" />

                        <Button Content="Cancel"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Background="#FF175AA8" 
                                BorderBrush="#FF175AA8" 
                                Margin="0,53,0,10"
                                Height="25"
                                Command="{Binding CancelCommand}"
                                />


                    </Grid>

                </Border>


            </Grid>



        </Grid>

    </Border>

</Window>
