<UserControl x:Class="i_freeze.View.DataControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:i_freeze.View" 
             xmlns:vm="clr-namespace:i_freeze.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="560" d:DesignWidth="650"
             Style="{StaticResource Page_Style}">

    <UserControl.DataContext>
        <vm:DataControlsViewModel/>
    </UserControl.DataContext>

    <Grid Background="Transparent">

        <TextBlock HorizontalAlignment="Center" Foreground="#FF175AA8" 
                   Height="43" Margin="0,25,0,0" TextWrapping="Wrap" 
                   VerticalAlignment="Top" Width="219"   
                   Text="Data Controls" FontSize="24"/>

        <Rectangle HorizontalAlignment="Center" Height="1" 
                   Margin="0,80,0,0" Stroke="#FF175AA8" 
                   VerticalAlignment="Top" Width="626"/>

        <ToggleButton x:Name="ScreenshotAnalyzer"  
                      Foreground="#FF175AA8"   
                      HorizontalAlignment="Left" 
                      Margin="20,130,0,0" VerticalAlignment="Top" 
                      Height="20" Width="40"  
                      FontSize="12" BorderBrush="#FF175AA8" Background="#FF175AA8"
                      IsChecked="{Binding IsScreenshotAnalyzer, Mode=TwoWay}"
                      Command="{Binding ScreenshotAnalyzerToggleCommand}"/>

        <TextBlock Text="Screenshot Analayzer" 
                   Foreground="#FF175AA8" 
                   VerticalAlignment="Top"
                   Margin="90,131,384,0" Padding="3,0,0,0"
                   Height="20" 
                   Background="White" FontSize="15" FontFamily="arial"/>

        <ToggleButton x:Name="RealtimeClassification"  
                      Foreground="#FF175AA8"   
                      HorizontalAlignment="Left" 
                      IsChecked="{Binding IsRealtimeClassification, Mode=TwoWay}"
                      Command="{Binding RealtimeClassificationToggleCommand}"
                      Margin="338,131,0,0" 
                      VerticalAlignment="Top" 
                      Height="20" Width="39"  
                      BorderBrush="#FF175AA8" Background="#FF175AA8" />

        <TextBlock Text="Realtime Classification" 
                   Foreground="#FF175AA8"   
                   HorizontalAlignment="Left" 
                   Margin="407,131,0,0" Padding="3,0,0,0"
                   VerticalAlignment="Top" 
                   Height="20" Width="174" Background="White" 
                   FontSize="15" FontFamily="arial"/>

        <ToggleButton  x:Name="AutomaticClassification" 
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       IsChecked="{Binding IsAutomaticClassification, Mode=TwoWay}"
                       Command="{Binding AutomaticClassificationToggleCommand}"
                       Margin="20,176,0,0" Background="#FF175AA8" 
                       Foreground="#FF175AA8" Height="20" Width="40"/>

        <TextBlock Text="Automatic Classification" 
                   Foreground="#FF175AA8"   
                   HorizontalAlignment="Left" 
                   Margin="92,176,0,0" Padding="3,0,0,0"
                   VerticalAlignment="Top" 
                   Height="20" Width="174" 
                   Background="White" FontSize="15" FontFamily="arial" />

        <ToggleButton  x:Name="DecryptAllData"  
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       IsChecked="{Binding IsDecryptAllData, Mode=TwoWay}"
                       Command="{Binding DecryptAllDataToggleCommand}"
                       Margin="338,177,0,0" 
                       Background="#FF175AA8" 
                       Foreground="#FF175AA8" Height="20" Width="39"/>

        <TextBlock Text="Decrypt All Data" Foreground="#FF175AA8"   
                   HorizontalAlignment="Left" Margin="407,176,0,0" 
                   Padding="3,0,0,0"
                   VerticalAlignment="Top" Height="20" Width="174" 
                   Background="White" FontSize="15" FontFamily="arial"/>

      

    </Grid>
</UserControl>
