<Window x:Class="i_freeze.View.UpgradeBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:i_freeze.View" 
        xmlns:vm="clr-namespace:i_freeze.ViewModel" 
        xmlns:h="clr-namespace:i_freeze.Commands" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d" Background="Transparent" 
        ResizeMode="NoResize" AllowsTransparency="True" 
        Height = "205" Width = "450" 
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" Topmost="True">

    <Window.DataContext>
        <vm:UpgradeBoxWindowViewModel/>
    </Window.DataContext>

    <i:Interaction.Behaviors>
        <h:WindowDragAndDrop />
    </i:Interaction.Behaviors>


    <Border>
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" 
                      RenderingBias="Quality" 
                      ShadowDepth="0" 
                      Opacity="0.8"
                      Color="Black"
                      />
        </Border.Effect>
        
        <Grid Margin="20">

            <Border Background="Transparent" CornerRadius="10"/>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White"
                        CornerRadius="10 10 0 0">

                    <Grid>

                        <Image Source="/Images/logo I-freeze 3-3 and 10-03.jpg" Width="100" 
                               HorizontalAlignment="Left"
                               Margin="7 0 0 0"
                        />

                        <Border HorizontalAlignment="Right" 
                                Margin="0,0,0,0"
                                Height="40" Width="40"
                                Style="{StaticResource CloseWindow}"
                                CornerRadius="0 10 0 0"
                                >

                            <Button Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}" 
                                    Width="25" Height="25" Background="{x:Null}" 
                                    BorderBrush="{x:Null}" Foreground="#FF175AA8"
                                    Command="{Binding CloseCommand}"
                                    >

                                <materialDesign:PackIcon Kind="Close" HorizontalAlignment="Center"/>
                            </Button>
                        </Border>
                    </Grid>

                </Border>

                <Border Grid.Row="1" Background="#FF175AA8"
                        CornerRadius="0 0 10 10">

                    <Grid Background = "#FF175AA8" Margin="28,15,30,14">

                        <TextBlock x:Name="ScanResult" 
                           Text="{Binding Message}" 
                           Foreground="White"  
                           TextWrapping="Wrap" FontSize="15" 
                           HorizontalAlignment="Center" 
                           TextAlignment="Center" Margin="0,0,0,41"/>

                        <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                            materialDesign:ButtonAssist.CornerRadius="10" 
                            BorderThickness="2" 
                            BorderBrush="White"
                            Background="White" Foreground="#FF175AA8"
                            Margin="110,51,110,3"
                            Content="Upgrade Now"
                            Command="{Binding UpgradeCommand}"
                            />

                    </Grid>

                </Border>



            </Grid>

        </Grid>
    </Border>


</Window>
