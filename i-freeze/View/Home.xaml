<UserControl x:Class="i_freeze.View.Home"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:i_freeze.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="650"
             Background="White"
             Style="{StaticResource Page_Style}">

    <UserControl.DataContext>
        <vm:HomeViewModel/>
    </UserControl.DataContext>

    <Grid>

        <!-- Version -->
        <!--<StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,20,20,0">
            <TextBlock Text="Version Number : "
                       Foreground="#FF175AA8"/>
            <TextBlock Text="{Binding Version}"
                       Foreground="#FF175AA8"/>
        </StackPanel>-->

        <!-- MAIN CONTENT -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <!-- MAIN ICON -->
            <Image Source="/Images/ICELOCK-01.jpg"
                   Width="230"
                   Height="200"
                   Margin="0,0,0,40"/>

            <!-- BUTTONS -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <!-- SHARE FILE -->
                <Button Width="175"
                        Height="110"
                        Margin="0,0,30,0"
                        Background="White"
                        BorderBrush="#FF175AA8"
                        Foreground="#FF175AA8"
                        FontSize="18"
                        FontWeight="Medium"
                        Command="{Binding SharedFile}">

                    <StackPanel>
                        <Image Height="50"
                               Width="50"
                               Source="/Images/share.png"
                               Margin="0,0,0,10"/>
                        <TextBlock Text="Share File"
                                   FontFamily="Arial"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- CLASSIFY FILES -->
                <Button Width="175"
                        Height="110"
                        Margin="0,0,30,0"
                        Background="White"
                        BorderBrush="#FF175AA8"
                        Foreground="#FF175AA8"
                        FontSize="18"
                        FontWeight="Medium"
                        Command="{Binding EncryptFilesCommand}">

                    <StackPanel>
                        <Image Height="50"
                               Width="50"
                               Source="/Images/lock.png"
                               Margin="0,0,0,10"/>
                        <TextBlock Text="Encrypt Files"
                                   FontFamily="Arial"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- SECURITY UPDATES -->
                <Button Width="175"
                        Height="110"
                        Background="White"
                        BorderBrush="#FF175AA8"
                        Foreground="#FF175AA8"
                        FontSize="18"
                        FontWeight="Medium"
                        Command="{Binding SecurityUpdateCommand}">

                    <StackPanel>
                        <Image Height="50"
                               Width="50"
                               Source="/Images/sync.png"
                               Margin="0,0,0,10"/>
                        <TextBlock Text="Security Updates"
                                   FontFamily="Arial"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>

        </StackPanel>

    </Grid>
</UserControl>
