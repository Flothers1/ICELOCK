<UserControl x:Class="i_freeze.View.SettingsAdmin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:i_freeze.View"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:i_freeze.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="560" d:DesignWidth="650"
             Style="{StaticResource Page_Style}">


    <UserControl.DataContext>
        <vm:SettingsAdminViewModel/>
    </UserControl.DataContext>


    <Grid Background="Transparent">

        <TextBlock HorizontalAlignment="Center" 
                   Foreground="#FF175AA8" 
                   Height="43" 
                   Margin="0 25 0 0"
                   TextWrapping="Wrap" 
                   VerticalAlignment="Top" Width="94" 
                   FontSize="24" Text="Settings"/>

        <Rectangle HorizontalAlignment="Center" 
                   Height="1" Margin="0 80 0 0" 
                   Stroke="#FF175AA8" 
                   VerticalAlignment="Top" Width="627"/>


        <TextBlock HorizontalAlignment="Left" 
                   Foreground="#FF175AA8" 
                   Height="33" Margin="20,95,0,0" 
                   TextWrapping="Wrap" 
                   VerticalAlignment="Top" 
                   Width="149"  Text="IceLock Update" 
                  FontSize="15" FontFamily="arial" />

        <Label Content="Check for new software release from this button&#xA;It may decrease the response of the computer for up to 10 minutes" 
                HorizontalAlignment="Left" 
                Foreground="#FF175AA8" 
                Width="366" Margin="20,112,0,410" FontFamily="arial" FontSize="12"/>

        <Button Content="Check for updates" 
                HorizontalAlignment="Left" Height="38" 
                Margin="450,112,0,0" 
                VerticalAlignment="Top" 
                Width="151" 
                Background="#FF175AA8"
                Command="{Binding CheckUpdatesCommand}" />

        <TextBlock HorizontalAlignment="Left" 
                   Foreground="#FF175AA8" 
                   Height="33" Margin="20,170,0,0" 
                   TextWrapping="Wrap" 
                   VerticalAlignment="Top" 
                   Width="149"  Text="Request Expert" 
                   FontSize="15" FontFamily="arial" />

        <Label HorizontalAlignment="Left" Foreground="#FF175AA8" Width="366" Margin="20,186,0,325" FontFamily="arial">
            <TextBlock TextAlignment="Justify" Width="358">
                <Run Text="You can submit a request for i-Freeze team to report "/>
                    <LineBreak/>
                <Run Text="any incident for technical investigation"/>
            </TextBlock>
        </Label>

        <Button Content="Request Expert" 
                HorizontalAlignment="Left" 
                Height="38" Margin="450,186,0,0" 
                VerticalAlignment="Top" Width="151" 
                Background="#FF175AA8"
                Command="{Binding RequestExpertCommand}"/>

        <TextBlock HorizontalAlignment="Left" 
                   Foreground="#FF175AA8" 
                   Height="33" Margin="20,240,0,0" 
                   TextWrapping="Wrap" 
                   VerticalAlignment="Top" 
                   Width="305"  Text="Re-enable USB connected device" 
                   FontSize="15" FontFamily="arial" />

        <Label Content="If your device was blocking USB devices, so you need to connect&#xA;your blocked device and click here to enable it again" 
                HorizontalAlignment="Left" 
                
                Foreground="#FF175AA8" 
                Width="350" Margin="20,256,0,255" FontFamily="arial"/>

        <Button Content="Enable" 
                HorizontalAlignment="Left" 
                Height="38" Margin="450,255,0,0"
                VerticalAlignment="Top" Width="151" 
                Background="#FF175AA8"
                Command="{Binding ReEnableUSBCommand}"/>

        <TextBlock HorizontalAlignment="Left" 
                   Foreground="#FF175AA8" 
                   Height="33" Margin="20,310,0,0" 
                   TextWrapping="Wrap" 
                   VerticalAlignment="Top" 
                   Width="317"  Text="Re-enable connect USB tethering" 
                  FontSize="15" FontFamily="arial" />

        <Label Content="If your device was blocking USB tethering, so you need to connect&#xA; your blocked device and click here to enable it again" 
                HorizontalAlignment="Left" 
                 
                Foreground="#FF175AA8" 
                Width="367" Margin="20,326,0,185"/>

        <Button Content="Enable" 
                HorizontalAlignment="Left" 
                Height="38" Margin="450,335,0,0"
                VerticalAlignment="Top" Width="151" 
                Background="#FF175AA8"
                Command="{Binding ReEnableTeatheringCommand}"/>

        <TextBlock HorizontalAlignment="Left" 
                   Foreground="#FF175AA8" 
                   Height="33" Margin="58,394,0,0" 
                   TextWrapping="Wrap" 
                   VerticalAlignment="Top" 
                   Width="373"  Text="Tamper Protection (Controlled Centrally)" 
                   FontSize="15" FontFamily="arial" />

        <Label Content="This option is preventing the user to uninstall IceLock &#xA;It should be enabled first to unistall the software" 
                HorizontalAlignment="Left" 
                 
                Foreground="#FF175AA8" 
                Width="367" Margin="20,415,0,89"/>

        <ToggleButton  x:Name="PowerShell"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       IsChecked="{Binding IsTamperProtection, Mode=OneWay}"
                       PreviewMouseLeftButtonDown="TamperProtection_PreviewMouseLeftButtonDown"
                       Command="{Binding TamperProtectionToggleCommand}"
                       Margin="20,389,0,0"
                       Background="#FF175AA8" 
                       Foreground="#FF175AA8" Height="26" Width="33" RenderTransformOrigin="0.493,-0.151"/>


    </Grid>

</UserControl>
