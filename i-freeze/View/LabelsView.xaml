<UserControl x:Class="i_freeze.View.LabelsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:i_freeze.ViewModel"
             xmlns:local="clr-namespace:i_freeze.View"
             mc:Ignorable="d"
             d:DesignHeight="560" d:DesignWidth="650"
             Style="{StaticResource Page_Style}">
    <UserControl.DataContext>
        <vm:LabelsViewModel/>
    </UserControl.DataContext>

    <Grid Background="Transparent">
        <!-- Title -->
        <TextBlock HorizontalAlignment="Center" 
                   Foreground="#FF175AA8" 
                   Height="43" 
                   Margin="0,25,0,0"
                   TextWrapping="Wrap" 
                   VerticalAlignment="Top" 
                   Width="262"  
                   Text="Labels" 
                   FontSize="24"
                   TextAlignment="Center"/>

        <!-- Separator Line -->
        <Rectangle HorizontalAlignment="Center" 
                   Height="1" 
                   Margin="0,80,0,0" 
                   Stroke="#FF175AA8" 
                   VerticalAlignment="Top" 
                   Width="627"/>

        <!-- Two Column Layout -->
        <Grid Margin="12,107,12,135">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Permitted Labels -->
            <Border Grid.Column="0" 
                    Background="White" 
                    CornerRadius="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" 
                            Background="#FFF0F0F0" 
                            BorderBrush="#FFD0D0D0"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <TextBlock Text="Permitted Labels" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   Foreground="#FF175AA8"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Separator -->
                    <Rectangle Grid.Row="1" 
                               Fill="#FFD0D0D0" 
                               Height="1"/>

                    <!-- Content -->
                    <ScrollViewer Grid.Row="2" 
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="8">
                        <ItemsControl ItemsSource="{Binding PermittedLabels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4,0,4" 
                                            Padding="12,8" 
                                            CornerRadius="2" 
                                            Background="#FFE3F2FD" 
                                            BorderBrush="#FF175AA8" 
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding}" 
                                                       FontSize="13" 
                                                       Foreground="#FF175AA8"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding}"/>

                                            <!-- Status Indicator -->
                                            <Ellipse Grid.Column="1"
                                                     Width="8" 
                                                     Height="8"
                                                     Fill="#4CAF50"
                                                     Margin="8,0,0,0"
                                                     VerticalAlignment="Center"
                                                     ToolTip="Active"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right Column: Classification Labels -->
            <Border Grid.Column="2" 
                    Background="White" 
                    CornerRadius="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" 
                            Background="#FFF0F0F0" 
                            BorderBrush="#FFD0D0D0"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <TextBlock Text="Classification Labels" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   Foreground="#FF175AA8"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Separator -->
                    <Rectangle Grid.Row="1" 
                               Fill="#FFD0D0D0" 
                               Height="1"/>

                    <!-- Content -->
                    <ScrollViewer Grid.Row="2" 
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="8">
                        <ItemsControl ItemsSource="{Binding ClassificationLabels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4,0,4" 
                                            Padding="12,8" 
                                            CornerRadius="2" 
                                            Background="#FFF5F5F5" 
                                            BorderBrush="#FFD0D0D0" 
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding}" 
                                                       FontSize="13" 
                                                       Foreground="#424242"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding}"/>

                                            <!-- Status Indicator -->
                                            <Ellipse Grid.Column="1"
                                                     Width="8" 
                                                     Height="8"
                                                     Fill="#FF9800"
                                                     Margin="8,0,0,0"
                                                     VerticalAlignment="Center"
                                                     ToolTip="Classification"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

