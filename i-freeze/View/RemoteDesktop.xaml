<UserControl x:Class="i_freeze.View.RemoteDesktop"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:i_freeze.View"
             xmlns:vm="clr-namespace:i_freeze.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="560" d:DesignWidth="650"
             Style="{StaticResource Page_Style}">

    <!--<UserControl.DataContext>
        <vm:RemoteDesktopViewModel/>
    </UserControl.DataContext>-->

    <Grid Background="Transparent">

        <TextBlock HorizontalAlignment="Center" 
               Foreground="#FF175AA8" 
               Height="43" 
               Margin="0,25,0,0"
               TextWrapping="Wrap" 
               VerticalAlignment="Top" Width="177" 
               FontSize="24" Text="Remote Desktop"/>

        <Rectangle HorizontalAlignment="Center" 
               Height="1" Margin="0 80 0 0" 
               Stroke="#FF175AA8" 
               VerticalAlignment="Top" Width="627"/>


        <TextBlock x:Name="IP" FontSize="15" FontFamily="arial"  Foreground="#FF175AA8" TextWrapping="Wrap" Text="{Binding IP}" Margin="335,110,0,0"/>
        <TextBlock x:Name="MyIP" FontSize="15" FontFamily="arial" Foreground="#FF175AA8" TextWrapping="Wrap" Text="My Device IP :" Margin="225,110,-25,0"/>



        <TextBlock HorizontalAlignment="Left" 
               Foreground="#FF175AA8" 
               Height="33" Margin="20,224,0,0" 
               TextWrapping="Wrap" 
               VerticalAlignment="Top" 
               Width="231"  Text="Connect to remote device" 
               FontSize="15" FontFamily="arial" />

        <Button Content="Connect" 
            HorizontalAlignment="Center" Height="28" 
            Margin="0,221,0,0" 
            VerticalAlignment="Top" 
            Width="100" 
            Background="#FF175AA8"
            Command="{Binding ConnectCommand}"/>

        <TextBlock HorizontalAlignment="Left" 
               Foreground="#FF175AA8" 
               Height="33" Margin="20,275,0,0" 
               TextWrapping="Wrap" 
               VerticalAlignment="Top" 
               Width="231"  Text="Allow remote connection" 
               FontSize="15" FontFamily="arial" />

        <Button Content="Allow" 
            HorizontalAlignment="Center" 
            Height="28" 
            VerticalAlignment="Center" Width="100" 
            Background="#FF175AA8"
            Command="{Binding AllowCommand}"/>

        <StackPanel Margin="15,419,-25,-269" >
            <TextBlock FontSize="12" TextWrapping="Wrap"
               Text="Note: This feature requires the installation of remote desktop plugin using this link."/>
            <TextBox Text="https://security.flothers.com/download/javaRemoteDesktop.exe"
             IsReadOnly="True"
             Cursor="Hand"
             Foreground="Blue"
             Background="Transparent"
             BorderThickness="0"
             FontSize="12" FontFamily="arial" RenderTransformOrigin="0.467,9.128" Height="49"
             >
                <TextBox.InputBindings >
                    <MouseBinding Gesture="LeftClick"
                          Command="{Binding OpenLinkCommand}"
                          CommandParameter="https://security.flothers.com/download/javaRemoteDesktop.exe"  />
                </TextBox.InputBindings>
            </TextBox>
        </StackPanel>


    </Grid>
</UserControl>
