<UserControl x:Class="i_freeze.View.Settings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:i_freeze.View"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:i_freeze.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="560" d:DesignWidth="650"
             Style="{StaticResource Page_Style}">

    <UserControl.DataContext>
        <vm:SettingsViewModel/>
    </UserControl.DataContext>

    <Grid Background="Transparent">

        <TextBlock HorizontalAlignment="Center" 
                   Foreground="#FF175AA8" 
                   Height="43" 
                   Margin="0 25 0 0"
                   TextWrapping="Wrap" 
                   VerticalAlignment="Top" Width="94" 
                   FontSize="24" Text="Settings"/>

        <Rectangle HorizontalAlignment="Center" 
                   Height="1" Margin="0 80 0 0" 
                   Stroke="#FF175AA8" 
                   VerticalAlignment="Top" Width="627"/>


        <TextBlock HorizontalAlignment="Left" 
                   Foreground="#FF175AA8" 
                   Height="25" Margin="20,95,0,0" 
                   TextWrapping="Wrap" 
                   VerticalAlignment="Top" 
                   Width="123"  Text="ICE LOCK Update" 
                    FontSize="15" FontFamily="arial" />

        <Label Content="Check for new software release from this button&#xA;It may decrease the response of the computer for up to 10 minutes" 
                HorizontalAlignment="Left" 
                Margin="20,113,0,407"
                Foreground="#FF175AA8" 
                Width="364" 
               FontSize="12"
               />

        <Button Content="Check for updates" 
                HorizontalAlignment="Left" Height="34" 
                Margin="450,112,0,0" 
                VerticalAlignment="Top" 
                Width="147" 
                Background="#FF175AA8"
                Command="{Binding CheckUpdatesCommand}" />

        <TextBlock HorizontalAlignment="Left" 
                   Foreground="#FF175AA8" 
                   Height="33" Margin="20,170,0,0" 
                   TextWrapping="Wrap" 
                   VerticalAlignment="Top" 
                   Width="149"  Text="Request Expert" 
                  FontSize="15" FontFamily="arial" />

        <Label HorizontalAlignment="Left"  Foreground="#FF175AA8" Width="430" Margin="20,186,0,320">
            <TextBlock TextAlignment="Justify" Height="39" Width="431"><Run Text="You can submit a request for ICE LOCK team to report "/><LineBreak/><Run Text="any incident for technical investigation"/></TextBlock>
        </Label>

        <Button Content="Request Expert" 
                HorizontalAlignment="Left" 
                Height="35" Margin="450,190,0,0" 
                VerticalAlignment="Top" Width="147" 
                Background="#FF175AA8"
                Command="{Binding RequestExpertCommand}" RenderTransformOrigin="0.472,1.405"/>

    </Grid>

</UserControl>
