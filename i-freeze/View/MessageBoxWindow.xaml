<Window x:Class="i_freeze.View.MessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:i_freeze.View" 
        xmlns:vm="clr-namespace:i_freeze.ViewModel" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        xmlns:h="clr-namespace:i_freeze.Commands"
        mc:Ignorable="d" Background="Transparent" 
        ResizeMode="NoResize" AllowsTransparency="True" 
        Height = "205" Width = "470" 
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" Topmost="True">

    <Window.DataContext>
        <vm:MessageBoxWindowViewModel/>
    </Window.DataContext>

    <i:Interaction.Behaviors>
        <h:WindowDragAndDrop />
    </i:Interaction.Behaviors>


    <Border>
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" 
                      RenderingBias="Quality" 
                      ShadowDepth="0" 
                      Opacity="0.8"
                      Color="Black"
                      />
        </Border.Effect>

        <Grid Margin="20">

            <Border Background="Transparent" CornerRadius="10"/>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White"
                        CornerRadius="10 10 0 0" Margin="0,0,0,10">

                    <Grid>
                        <!--IceLockHeader.jpg-->
                        <Image Source="/Images/ICELOCK-01.jpg" Width="50" 
                               HorizontalAlignment="Left"
                               Margin="7,0,0,0" Height="25" VerticalAlignment="Center"
                               />

                        <Border HorizontalAlignment="Right" 
                                Margin="0,0,0,0"
                                Height="40" Width="40"
                                Style="{StaticResource CloseWindow}"
                                CornerRadius="0 10 0 0"
                                >

                            <Button Margin="0 0 0 10" Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}" 
                                    Width="25" Height="25" Background="{x:Null}"  
                                    BorderBrush="{x:Null}" Foreground="#FF175AA8"
                                    Command="{Binding CloseCommand}"
                                    >

                                <materialDesign:PackIcon Kind="Close" HorizontalAlignment="Center"/>
                            </Button>
                        </Border>
                    </Grid>

                </Border>

                <Border Background="#0453c3"
                        CornerRadius="0 0 10 10" Margin="0,30,0,0" Grid.RowSpan="2">

                    <Grid Background = "#0453c3" Margin="28,15,30,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14*"/>
                            <ColumnDefinition Width="121*"/>
                            <ColumnDefinition Width="237*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="ScanResult" 
                               Text="{Binding Message}" 
                               Foreground="White"  
                               TextWrapping="Wrap" FontSize="15" 
                               HorizontalAlignment="Left" 
                               TextAlignment="Center" Margin="7,0,0,41" Grid.ColumnSpan="3" Width="342"/>

                        <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                            materialDesign:ButtonAssist.CornerRadius="10" 
                            BorderThickness="2" 
                            BorderBrush="White"
                            Background="White" Foreground="#FF175AA8"
                            Content="OK" Margin="101,70,115,8"
                            Command="{Binding CloseCommand}" Grid.Column="1" Grid.ColumnSpan="2"
                            />
                    </Grid>

                </Border>



            </Grid>

        </Grid>
    </Border>

</Window>
