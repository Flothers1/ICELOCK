<UserControl x:Class="i_freeze.View.ChangePassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:i_freeze.View"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:i_freeze.ViewModel" 
             xmlns:components="clr-namespace:i_freeze.Components"
             mc:Ignorable="d" 
             d:DesignHeight="560" d:DesignWidth="650"
             Style="{StaticResource Page_Style}">


    <UserControl.DataContext>
        <vm:ChangePasswordViewModel/>
    </UserControl.DataContext>


    <Border Background="#FF175AA8" CornerRadius="0 0 10 0">

        <Grid>

            <Image  Height="151" VerticalAlignment="Top" 
                Margin="138,100,162,0" 
                Source="/Images/cover fecbook I-freeze-03 (2).png"/>


            <StackPanel Margin="138,236,162,84">
                
                <TextBlock Text="Enter new password" 
                           Margin="20" Foreground="White" 
                           TextAlignment="Center" 
                           FontSize="15" FontFamily="arial"/>
                
                <StackPanel Orientation="Horizontal" Margin="10">
                    
                    <materialDesign:PackIcon Kind="Lock" 
                                             Width="25" Height="25" 
                                             Foreground="White"/>

                    <components:BindablePasswordBox x:Name="NewPassword"
                                Margin="10 0"
                                materialDesign:HintAssist.Hint="*******"
                                Foreground="White" Width="250"
                                Password="{Binding NewPassword}"/>

                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="10">
                    
                    <materialDesign:PackIcon Kind="Lock"
                                             Width="25" Height="25" 
                                             Foreground="White"/>

                    <components:BindablePasswordBox x:Name="ConfirmPassword"
                                Margin="10 0"
                                materialDesign:HintAssist.Hint="*******"
                                Foreground="White" Width="250"
                                Password="{Binding ConfirmPassword}"/>

                </StackPanel>
                
                <StackPanel Margin="10" Orientation="Horizontal" HorizontalAlignment="Center">
                    
                    <Button Width="100" Height="40" 
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            materialDesign:ButtonAssist.CornerRadius="10" 
                            BorderThickness="2" BorderBrush="#FF175AA8"
                            Background="#FFC7CFD8" Foreground="#FF175AA8"  
                            x:Name="btnLogin"
                            Content="Confirm"
                            IsDefault="True"
                            Command="{Binding ConfirmCommand}"/>
                    
                    <!--<Button Width="100" Height="40" 
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            materialDesign:ButtonAssist.CornerRadius="10" 
                            BorderThickness="2" BorderBrush="#FF175AA8"
                            Background="#FFC7CFD8" Foreground="#FF175AA8"  
                            x:Name="btnBack" Content="Back"/>-->

                </StackPanel>

            </StackPanel>


        </Grid>
    </Border>


</UserControl>
