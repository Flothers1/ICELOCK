<UserControl x:Class="i_freeze.View.Activation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
             xmlns:local="clr-namespace:i_freeze.View" 
             xmlns:vm="clr-namespace:i_freeze.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="560" d:DesignWidth="650"
             Style="{StaticResource Page_Style}">


    <UserControl.DataContext>
        <vm:ActivationViewModel/>
    </UserControl.DataContext>

    <Grid Background="Transparent">

        <Label Content="Activation Code" HorizontalAlignment="Left"
               Height="30"
                Foreground="#FF175AA8" FontSize="15" Margin="50,232,0,298" FontFamily="arial" />

        <TextBox x:Name="text1" 
                 materialDesign:HintAssist.Hint="JQTFU-DUKMV-LKIKC-UQDZL"  
                 HorizontalAlignment="Left"
                 Text="{Binding Liscence, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="260" Height="30" 
                 VerticalAlignment="Top" BorderBrush="#FF175AA8" 
                 CaretBrush="#FF175AA8" Foreground="#FF175AA8" 
                 SelectionBrush="#FF175AA8" Margin="193,232,0,0"/>

        <Button Foreground="White" Background="#FF175AA8"
                Margin="148,306,310,222" x:Name="ButtonShowResults" 
                Content="Activate Progarm&#xD;&#xA;"
                Command="{Binding ActivateCommand}" FontSize="15" FontFamily="arial"/>
    </Grid>
</UserControl>
